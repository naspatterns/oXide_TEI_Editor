{
  "name": "oxide-tei-editor",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-icons": "npx tsx scripts/generateIcons.ts",
    "generate-schema": "npx tsx scripts/generateTeiSchema.ts",
    "generate-schema:download": "npx tsx scripts/generateTeiSchema.ts --download",
    "generate-p5-schema": "npx tsx scripts/generateFromP5.ts",
    "generate-p5-schema:download": "npx tsx scripts/generateFromP5.ts --download"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lint": "^6.8.0",
    "@uiw/react-codemirror": "^4.23.0",
    "codemirror": "^6.0.0",
    "idb-keyval": "^6.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
